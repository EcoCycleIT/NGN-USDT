# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# Public site URL (referral links + auth email redirects). Must match Supabase Site URL for that environment.
# Local: http://localhost:3000
# Vercel: https://your-project.vercel.app (set this in Vercel → Settings → Environment Variables for Production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Dashboard → Authentication → URL Configuration:
# - Site URL: same as NEXT_PUBLIC_APP_URL for that environment (use production URL for prod project / prod traffic).
# - Redirect URLs: include both local and prod callbacks, e.g.:
#   http://localhost:3000/auth/callback
#   https://your-project.vercel.app/auth/callback

# Virtual NGN deposit account (MVP placeholders)
VIRTUAL_BANK_NAME=Demo Bank PLC
VIRTUAL_ACCOUNT_NAME=NGN-USDT Exchange Collections
VIRTUAL_ACCOUNT_NUMBER=9988776655

# Dev-only dummy users (never enable in production)
ENABLE_DEV_DUMMY_AUTH=false
NEXT_PUBLIC_ENABLE_DEV_DUMMY_AUTH=false
DEV_BYPASS_PASSWORD=devpass123!

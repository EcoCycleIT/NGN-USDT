# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret

# App URL (referral links + auth). Must match Supabase Auth → URL Configuration → Site URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Add in Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback

# Virtual NGN deposit account (MVP placeholders)
VIRTUAL_BANK_NAME=Demo Bank PLC
VIRTUAL_ACCOUNT_NAME=NGN-USDT Exchange Collections
VIRTUAL_ACCOUNT_NUMBER=9988776655

## Twilio SMS (for Supabase Phone OTP)
SUPABASE_AUTH_SMS_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_AUTH_SMS_TWILIO_MESSAGE_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Dev-only OTP bypass (never enable in production)
ENABLE_DEV_OTP_BYPASS=false
NEXT_PUBLIC_ENABLE_DEV_OTP_BYPASS=false
DEV_BYPASS_PASSWORD=devpass123!
